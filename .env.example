# Database — local SQLite (default). On Vercel use Neon Postgres instead.
DATABASE_URL="file:./dev.db"

# --- Auth (required when deployed) ---
# Generate: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated. Only these Google accounts can sign in (shared one business DB).
ALLOWED_EMAILS="producedbyellis9@gmail.com,ehwlandscapes@gmail.com,hugow0604@gmail.com"

# Local dev only — skip login when OAuth isn't set up yet
AUTH_DISABLED="true"